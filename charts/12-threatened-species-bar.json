  "layer": [
    {
      "params": [
        {
          "name": "selectedStatus",
          "select": {
            "type": "point",
            "fields": [
              "status"
            ]
          }
        }
      ],
      "mark": {
        "type": "bar",
        "height": {
          "band": 0.72
        },
        "cornerRadiusEnd": 3
      },
      "encoding": {
        "y": {
          "field": "group",
          "type": "nominal",
          "title": null,
          "sort": {
            "field": "order",
            "order": "ascending"
          },
          "axis": {
            "labelFontSize": 12,
            "labelFontWeight": 600
          }
        },
        "x": {
          "field": "count",
          "type": "quantitative",
          "title": "Number of threatened species",
          "stack": "zero",
          "axis": {
            "format": "d"
          }
        },
        "color": {
          "field": "status",
          "type": "nominal",
          "title": "Threat level — click to highlight",
          "sort": [
            "Critically Endangered",
            "Endangered",
            "Vulnerable"
          ],
          "scale": {
            "domain": [
              "Critically Endangered",
              "Endangered",
              "Vulnerable"
            ],
            "range": [
              "#7b1c1c",
              "#c0392b",
              "#e3b23c"
            ]
          },
          "legend": {
            "orient": "bottom",
            "direction": "horizontal"
          }
        },
        "order": {
          "field": "status",
          "sort": [
            "Critically Endangered",
            "Endangered",
            "Vulnerable"
          ]
        },
        "opacity": {
          "condition": {
            "param": "selectedStatus",
            "empty": true,
            "value": 1
          },
          "value": 0.12
        },
        "tooltip": [
          {
            "field": "group",
            "title": "Group"
          },
          {
            "field": "status",
            "title": "Threat level"
          },
          {
            "field": "count",
            "title": "Species listed",
            "format": ","
          }
        ]
      }
    },
    {
      "transform": [
        {
          "aggregate": [
            {
              "op": "sum",
              "field": "count",
              "as": "total"
            }
          ],
          "groupby": [
            "group",
            "order"
          ]
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 6,
        "fontSize": 10.5,
        "fontWeight": 700,
        "color": "#2c2820",
        "font": "Inter, sans-serif"
      },
      "encoding": {
        "y": {
          "field": "group",
          "type": "nominal",
          "sort": {
            "field": "order",
            "order": "ascending"
          }
        },
        "x": {
          "field": "total",
          "type": "quantitative",
          "stack": null
        },
        "text": {
          "field": "total",
          "type": "quantitative",
          "format": ","
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "v": 2107,
            "label": "2,107 species total"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "right",
        "dx": -4,
        "dy": -8,
        "fontSize": 11,
        "fontWeight": 700,
        "color": "#7b1c1c",
        "font": "Inter, sans-serif"
      },
      "encoding": {
        "x": {
          "field": "v",
          "type": "quantitative"
        },
        "y": {
          "datum": "Plants"
        },
        "text": {
          "field": "label"
        }
      }
    }
  ],
  "config": {
    "background": null,
    "font": "Inter, sans-serif",
    "view": {
      "stroke": null
    },
    "padding": 5,
    "axis": {
      "labelFont": "Inter, sans-serif",
      "titleFont": "Inter, sans-serif",
      "labelColor": "#5b5347",
      "titleColor": "#3a342b",
      "titleFontWeight": 600,
      "gridColor": "#ebe6da",
      "domainColor": "#d2cbbb",
      "tickColor": "#d2cbbb",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "titlePadding": 8
    },
    "legend": {
      "labelFont": "Inter, sans-serif",
      "titleFont": "Inter, sans-serif",
      "labelColor": "#5b5347",
      "titleColor": "#3a342b",
      "labelFontSize": 11,
      "titleFontSize": 11.5
    },
    "title": {
      "font": "Fraunces, serif",
      "fontSize": 16,
      "anchor": "start",
      "color": "#2c2820",
      "fontWeight": 600,
      "subtitleFont": "Inter, sans-serif",
      "subtitleColor": "#7a7263",
      "subtitleFontSize": 12,
      "subtitlePadding": 6,
      "offset": 12
    }
  }
}