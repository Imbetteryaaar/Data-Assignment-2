{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Who is doing the protecting?",
    "subtitle": [
      "Share of Australia's land protected 2004–2024 (CAPAD biennial data). Drag the slider to",
      "watch protection grow year by year."
    ],
    "subtitleLineHeight": 16
  },
  "width": "container",
  "height": 300,
  "params": [
    {
      "name": "maxYear",
      "value": 2024,
      "bind": {
        "input": "range",
        "min": 2004,
        "max": 2024,
        "step": 2,
        "name": "▶ Show growth up to: "
      }
    }
  ],
  "data": {
    "values": [
      {
        "year": 2004,
        "layer": "Indigenous Protected Areas",
        "pct": 2.0
      },
      {
        "year": 2004,
        "layer": "Other protected land",
        "pct": 8.5
      },
      {
        "year": 2006,
        "layer": "Indigenous Protected Areas",
        "pct": 3.3
      },
      {
        "year": 2006,
        "layer": "Other protected land",
        "pct": 8.8
      },
      {
        "year": 2008,
        "layer": "Indigenous Protected Areas",
        "pct": 4.9
      },
      {
        "year": 2008,
        "layer": "Other protected land",
        "pct": 9.1
      },
      {
        "year": 2010,
        "layer": "Indigenous Protected Areas",
        "pct": 6.2
      },
      {
        "year": 2010,
        "layer": "Other protected land",
        "pct": 9.4
      },
      {
        "year": 2012,
        "layer": "Indigenous Protected Areas",
        "pct": 7.6
      },
      {
        "year": 2012,
        "layer": "Other protected land",
        "pct": 9.8
      },
      {
        "year": 2014,
        "layer": "Indigenous Protected Areas",
        "pct": 8.2
      },
      {
        "year": 2014,
        "layer": "Other protected land",
        "pct": 10.1
      },
      {
        "year": 2016,
        "layer": "Indigenous Protected Areas",
        "pct": 8.9
      },
      {
        "year": 2016,
        "layer": "Other protected land",
        "pct": 10.2
      },
      {
        "year": 2018,
        "layer": "Indigenous Protected Areas",
        "pct": 9.5
      },
      {
        "year": 2018,
        "layer": "Other protected land",
        "pct": 10.5
      },
      {
        "year": 2020,
        "layer": "Indigenous Protected Areas",
        "pct": 10.1
      },
      {
        "year": 2020,
        "layer": "Other protected land",
        "pct": 11.0
      },
      {
        "year": 2022,
        "layer": "Indigenous Protected Areas",
        "pct": 10.6
      },
      {
        "year": 2022,
        "layer": "Other protected land",
        "pct": 11.3
      },
      {
        "year": 2024,
        "layer": "Indigenous Protected Areas",
        "pct": 11.0
      },
      {
        "year": 2024,
        "layer": "Other protected land",
        "pct": 11.6
      }
    ]
  },
  "layer": [
    {
      "transform": [
        {
          "filter": "datum.year <= maxYear"
        }
      ],
      "mark": {
        "type": "area",
        "opacity": 0.88,
        "interpolate": "monotone"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "title": "Year",
          "scale": {
            "domain": [
              2004,
              2024
            ]
          },
          "axis": {
            "format": "d",
            "values": [
              2004,
              2006,
              2008,
              2010,
              2012,
              2014,
              2016,
              2018,
              2020,
              2022,
              2024
            ],
            "labelAngle": 0
          }
        },
        "y": {
          "field": "pct",
          "type": "quantitative",
          "title": "% of Australia's land",
          "stack": "zero",
          "scale": {
            "domain": [
              0,
              32
            ]
          },
          "axis": {
            "format": ".0f"
          }
        },
        "color": {
          "field": "layer",
          "type": "nominal",
          "title": "Type of protected land",
          "scale": {
            "domain": [
              "Indigenous Protected Areas",
              "Other protected land"
            ],
            "range": [
              "#bc6c25",
              "#5f9a52"
            ]
          },
          "legend": {
            "orient": "bottom",
            "direction": "horizontal"
          }
        },
        "order": {
          "field": "layer",
          "sort": "descending"
        },
        "tooltip": [
          {
            "field": "year",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "layer",
            "title": "Type"
          },
          {
            "field": "pct",
            "title": "Share of land (%)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "rule",
        "color": "#2c2820",
        "strokeDash": [
          3,
          3
        ],
        "strokeWidth": 1.4,
        "opacity": 0.35
      },
      "encoding": {
        "x": {
          "datum": {
            "expr": "maxYear"
          },
          "type": "quantitative"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "t": 30
          }
        ]
      },
      "mark": {
        "type": "rule",
        "strokeDash": [
          6,
          4
        ],
        "color": "#a23b2e",
        "strokeWidth": 1.5,
        "opacity": 0.8
      },
      "encoding": {
        "y": {
          "field": "t",
          "type": "quantitative"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "year": 2005,
            "t": 31,
            "lab": "2030 target: 30% of land"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "font": "Inter, sans-serif",
        "fontSize": 10.5,
        "fontWeight": 700,
        "color": "#a23b2e"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative"
        },
        "y": {
          "field": "t",
          "type": "quantitative"
        },
        "text": {
          "field": "lab",
          "type": "nominal"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "year": 2004,
            "pct": 2.0,
            "lab": "IPAs: just 2% in 2004"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 4,
        "dy": -10,
        "font": "Inter, sans-serif",
        "fontSize": 10,
        "fontStyle": "italic",
        "color": "#bc6c25"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative"
        },
        "y": {
          "field": "pct",
          "type": "quantitative"
        },
        "text": {
          "field": "lab",
          "type": "nominal"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.year == maxYear"
        },
        {
          "aggregate": [
            {
              "op": "sum",
              "field": "pct",
              "as": "total"
            }
          ],
          "groupby": [
            "year"
          ]
        },
        {
          "calculate": "format(datum.total, '.1f') + '% total in ' + datum.year",
          "as": "lab"
        }
      ],
      "mark": {
        "type": "text",
        "align": "right",
        "dx": -6,
        "dy": -12,
        "font": "Inter, sans-serif",
        "fontSize": 10.5,
        "fontWeight": 700,
        "color": "#2c2820"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative"
        },
        "y": {
          "field": "total",
          "type": "quantitative"
        },
        "text": {
          "field": "lab"
        }
      }
    }
  ],
  "config": {
    "background": null,
    "font": "Inter, sans-serif",
    "view": {
      "stroke": null
    },
    "padding": 5,
    "axis": {
      "labelFont": "Inter, sans-serif",
      "titleFont": "Inter, sans-serif",
      "labelColor": "#5b5347",
      "titleColor": "#3a342b",
      "titleFontWeight": 600,
      "gridColor": "#ebe6da",
      "domainColor": "#d2cbbb",
      "tickColor": "#d2cbbb",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "titlePadding": 8
    },
    "legend": {
      "labelFont": "Inter, sans-serif",
      "titleFont": "Inter, sans-serif",
      "labelColor": "#5b5347",
      "titleColor": "#3a342b",
      "labelFontSize": 11,
      "titleFontSize": 11.5
    },
    "title": {
      "font": "Fraunces, serif",
      "fontSize": 16,
      "anchor": "start",
      "color": "#2c2820",
      "fontWeight": 600,
      "subtitleFont": "Inter, sans-serif",
      "subtitleColor": "#7a7263",
      "subtitleFontSize": 12,
      "subtitlePadding": 6,
      "offset": 12
    }
  }
}