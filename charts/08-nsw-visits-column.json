      "Domestic visits to New South Wales national parks (millions), FY2018 to FY2025. Hover a bar",
      "for the story behind the year."
    ],
    "subtitleLineHeight": 16
  },
  "width": "container",
  "height": 360,
  "data": {
    "values": [
      {
        "year": "2018",
        "visits": 60.0,
        "cat": "Normal",
        "note": "Previous record — 60M visits"
      },
      {
        "year": "2019",
        "visits": 54.5,
        "cat": "Decline",
        "note": "Drought and early fire risk begins"
      },
      {
        "year": "2020",
        "visits": 33.0,
        "cat": "Disrupted",
        "note": "Black Summer bushfires + first COVID lockdowns"
      },
      {
        "year": "2021",
        "visits": 41.0,
        "cat": "Disrupted",
        "note": "COVID-19 restrictions continued"
      },
      {
        "year": "2022",
        "visits": 53.3,
        "cat": "Recovery",
        "note": "Post-pandemic recovery"
      },
      {
        "year": "2023",
        "visits": 60.2,
        "cat": "Recovery",
        "note": "Near-record levels"
      },
      {
        "year": "2024",
        "visits": 63.0,
        "cat": "Recovery",
        "note": "Continued growth"
      },
      {
        "year": "2025",
        "visits": 65.6,
        "cat": "Record",
        "note": "New record — 65.6M visits"
      }
    ]
